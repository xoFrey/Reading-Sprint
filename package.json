{
  "name": "reading-sprint-bot",
  "version": "1.0.0",
  "description": "Discord-Bot für Lese-Sprints mit XP-, Level- und Achievement-System",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
